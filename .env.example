# UI_INDEX Environment Variables
# Copy this file to .env and fill in your real API keys
# DO NOT commit .env to git — it is already in .gitignore

# ── Required for FEC funding data ───────────────────────────────────────────────
# Get your key at: https://api.open.fec.gov/developers/
FEC_API_KEY=your_fec_api_key_here

# ── Required for Census median income data ───────────────────────────────────────
# Get your key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# ── Optional: BLS average wages + CPI-U inflation data ─────────────────────────
# Used by: fetch_bls_baselines.py
# Without a key: 25 req/day limit (sufficient for this project's data refresh)
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# ── Optional: HUD Fair Market Rents (weekly housing costs) ──────────────────────
# Used by: fetch_housing.py
# Register for a free token at: https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_TOKEN=your_hud_token_here

# ── Congress.gov API (optional — DEMO_KEY public fallback available) ─────────────
# Used by: political_layer_builder.py
# Higher rate limits at: https://api.congress.gov/
# Without a key: DEMO_KEY is used automatically (rate-limited but functional)
CONGRESS_API_KEY=your_congress_api_key_here
